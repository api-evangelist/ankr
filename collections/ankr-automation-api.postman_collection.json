  "info": {
    "_postman_id": "25c9370e-a89e-4dcf-884e-8a52f220b346",
    "name": "Ankr Contract Automation API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "Ankr Contract Automation lets developers execute on-chain contract functions based\non time-based (CRON) and event-driven (custom-logic) triggers. The capability is\noperated through the Ankr Automation Dashboard and runs against Ankr's\ndecentralized node infrastructure. As of May 2026, BNB Smart Chain is the only\nsupported network — additional chains are on the roadmap.\n\n\nContact Support:\n Name: Ankr\n Email: support@ankr.com",
      "type": "text/plain"
    }
  }
