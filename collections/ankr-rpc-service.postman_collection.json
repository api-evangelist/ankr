          "name": "Ankr Execute JSON-RPC Call",
          "request": {
            "name": "Ankr Execute JSON-RPC Call",
            "description": {
              "content": "Execute a JSON-RPC 2.0 call against the selected chain. The `method` field\ncarries the EVM method name (`eth_blockNumber`, `eth_getBalance`,\n`eth_chainId`, `eth_call`, `eth_getLogs`, `eth_getTransactionByHash`,\n`eth_getTransactionReceipt`, `eth_sendRawTransaction`, etc.).\n",
              "type": "text/plain"
            },
            "url": {
              "path": [
                ""
              ],
              "host": [
                "{{baseUrl}}"
              ],
              "query": [],
              "variable": [
                {
                  "description": "Chain identifier in the URL path. (This can only be one of eth,bsc,polygon,arbitrum,optimism,base,avalanche,fantom,gnosis,linea,scroll,taiko,solana,aptos,stellar,tron)",
                  "type": "any",
                  "value": "{{chain}}",
                  "key": "chain"
                }
              ]
            },
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"2.0\",\n  \"method\": \"<string>\",\n  \"id\": \"<integer>\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
