  "info": {
    "_postman_id": "29121c71-5367-478b-a639-4fb345f9c98c",
    "name": "Ankr Liquid Staking API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Ankr Liquid Staking RESTful API surfaces staking metrics, the trustless\nexchange ratio, and validator metadata across Ankr's liquid staking tokens\n(ankrETH, ankrBNB, ankrPOL, ankrAVAX, ankrFTM, ankrDOT, etc.). It complements\nthe on-chain Smart Contract API exposed on Avalanche, Binance Smart Chain,\nEthereum, Fantom, and Polygon.\n\n\nContact Support:\n Name: Ankr\n Email: support@ankr.com",
      "type": "text/plain"
    }
  }
